modules = ["haskell-ghc9.8", "python-3.11", "postgresql-16", "nodejs-20", "haskell-ghc9.4"]
[agent]
expertMode = true
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CTMM Simulators"

[[workflows.workflow]]
name = "CTMM Simulators"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ".pythonlibs/bin/python unified_server.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python", "-m", "gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--workers=2", "unified_server:app"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "gitFull", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "symbiyosys", "tcl", "tk", "yices", "yosys", "zlib"]
