modules = ["haskell-ghc9.8", "python-3.11", "postgresql-16", "nodejs-20", "haskell-ghc9.4"]
[agent]
expertMode = true
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Church Machine IDE"

[[workflows.workflow]]
name = "Church Machine IDE"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3 server/app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--workers=2", "unified_server:app"]
build = ["pip", "install", "-r", "requirements.txt"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "gitFull", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "symbiyosys", "tcl", "tk", "yices", "yosys", "zlib", "nextpnr", "icestorm"]
