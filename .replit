modules = ["haskell-ghc9.8", "python-3.11", "postgresql-16", "nodejs-20", "haskell-ghc9.4"]
[agent]
expertMode = true
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Church Machine IDE"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-stale-cr7"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "hardware-sim"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "boot-image-matches-sim"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "boot-image-loads-and-boots"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "boot-image-upload-endpoint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "boot-image-serve-endpoints"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "assembler-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "assembler-tests-watch"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e-tests"

[[workflows.workflow]]
name = "Church Machine IDE"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3 server/app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "check-stale-cr7"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check_stale_cr7.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "hardware-sim"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m ctmm_cap_amaranth.testbench && python -m hardware.test_mwin_seal && python -m hardware.test_outform_mode2 && python -m hardware.test_shift_ops"

[[workflows.workflow]]
name = "boot-image-matches-sim"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m pytest tests/boot/test_boot_image_matches_simulator.py -v"

[[workflows.workflow]]
name = "boot-image-loads-and-boots"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/boot/test_boot_image_loads_and_boots.py -v"

[[workflows.workflow]]
name = "boot-image-upload-endpoint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/boot/test_boot_image_upload_endpoint.py -v"

[[workflows.workflow]]
name = "boot-image-serve-endpoints"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/boot/test_boot_image_serve_endpoints.py -v"

[[workflows.workflow]]
name = "assembler-tests"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node simulator/assembler_test.js && node simulator/lump_warning_test.js && node simulator/keystone_test.js && python3 -m pytest tests/simulator/test_clist_analysis.py -v"

[[workflows.workflow]]
name = "assembler-tests-watch"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node simulator/watch_assembler_tests.js"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "e2e-tests"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CHROMIUM=$(which chromium) && mkdir -p .cache/ms-playwright/chromium-1217/chrome-linux64 && ln -sf \"$CHROMIUM\" .cache/ms-playwright/chromium-1217/chrome-linux64/chrome && PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npx --yes playwright test"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 23636
externalPort = 3001

[[ports]]
localPort = 23637
externalPort = 3002

[[ports]]
localPort = 23638
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "1", "--threads", "8", "--timeout", "120", "--access-logfile", "-", "--error-logfile", "-", "server.app:app"]
build = ["pip", "install", "-r", "requirements.txt"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "fontconfig", "freetype", "ghostscript", "gitFull", "glib", "harfbuzz", "icestorm", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "nextpnr", "openjpeg", "openssl", "pango", "pkg-config", "rustc", "symbiyosys", "tcl", "tk", "yices", "yosys", "zlib"]

[userenv]

[userenv.shared]
BUILD_SIGNING_KEY = "2026411604PMkjhh0590"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000
