modules = ["haskell-ghc9.8", "python-3.11", "postgresql-16", "nodejs-20", "haskell-ghc9.4"]
[agent]
expertMode = true
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Church Machine IDE"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "boot-image-matches-sim"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "boot-image-loads-and-boots"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "hardware-sim"

[[workflows.workflow]]
name = "Church Machine IDE"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3 server/app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "boot-image-matches-sim"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m pytest tests/test_boot_image_matches_simulator.py -v"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "boot-image-loads-and-boots"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_boot_image_loads_and_boots.py -v"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "hardware-sim"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m ctmm_cap_amaranth.testbench"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 23636
externalPort = 3001

[[ports]]
localPort = 23637
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "1", "--threads", "8", "--timeout", "120", "--access-logfile", "-", "--error-logfile", "-", "server.app:app"]
build = ["pip", "install", "-r", "requirements.txt"]

[nix]
channel = "stable-25_05"
packages = ["fontconfig", "freetype", "ghostscript", "gitFull", "glib", "harfbuzz", "icestorm", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "nextpnr", "openjpeg", "pango", "symbiyosys", "tcl", "tk", "yices", "yosys", "zlib"]

[userenv]

[userenv.shared]
BUILD_SIGNING_KEY = "2026411604PMkjhh0590"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000
