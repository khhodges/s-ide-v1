            z = z + 4091
        }
        dx = y >> 5
        dy = x >> 5
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 2047
        } else {
            x = x + dx
            y = y - dy
            z = z + 2047
        }
        dx = y >> 6
        dy = x >> 6
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 1024
        } else {
            x = x + dx
            y = y - dy
            z = z + 1024
        }
        dx = y >> 7
        dy = x >> 7
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 512
        } else {
            x = x + dx
            y = y - dy
            z = z + 512
        }
        dx = y >> 8
        dy = x >> 8
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 256
        } else {
            x = x + dx
            y = y - dy
            z = z + 256
        }
        dx = y >> 9
        dy = x >> 9
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 128
        } else {
            x = x + dx
            y = y - dy
            z = z + 128
        }
        dx = y >> 10
        dy = x >> 10
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 64
        } else {
            x = x + dx
            y = y - dy
            z = z + 64
        }
        dx = y >> 11
        dy = x >> 11
        if (z >= 0) {
            x = x - dx
            y = y + dy
            z = z - 32
        } else {
            x = x + dx
            y = y - dy
            z = z + 32
        }
        if (neg == 1) {
            y = 0 - y
        }
        return(y)
    }

