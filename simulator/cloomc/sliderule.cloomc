            z = z + 32
        } else {
            x = x - dx
            y = y + dy
            z = z - 32
        }
        if (swap == 1) {
            pival = 102944
            z = pival - z
        }
        if (neg == 1) {
            z = 0 - z
        }
        return(z)
    }

    method Signum(n) {
        if (n > 0) {
            return(1)
        }
        if (n < 0) {
            result = 0 - 1
            return(result)
        }
        return(0)
    }
}
