// ============================================================
// Abstraction:  SlideRule
// Description:  Logarithmic-style math via CORDIC integer arithmetic
// Author:       Church Machine Educational Platform
// Version:      1.0
// Created:      2026-05-09
// Language:     CLOOMC++
// Dependencies: Constants
// ============================================================
// Methods:
//   1. Multiply(a, b) — binary shift-and-add multiplication
//   2. Divide(a, b) — repeated subtraction integer division
//   3. Sqrt(n) — integer square root (digit-by-digit method)
//   4. Mod(a, b) — remainder after integer division
//   5. Sin(angle) — CORDIC sine (scaled integer, not degrees)
//   6. Cos(angle) — CORDIC cosine
//   7. Tan(angle) — CORDIC tangent
//   8. Atan(y, x) — CORDIC arc-tangent
//   9. Exp(x) — exponential approximation
//  10. Ln(x) — natural logarithm approximation
//  11. Pow(base, exp) — integer power
//  12. Abs(n) — absolute value
//  13. Max(a, b) — maximum of two values
//  14. Min(a, b) — minimum of two values
//  15. Clamp(x, lo, hi) — clamp to [lo, hi]
//  16. GCD(a, b) — greatest common divisor (Euclidean algorithm)
//  17. LCM(a, b) — least common multiple
//  18. Log2(n) — integer floor log base 2
//  19. Bernoulli(n) — nth Bernoulli number (rational: numerator, denominator)
//  20. Factorial(n) — factorial n!
//  21. Fibonacci(n) — nth Fibonacci number
//  22. IsPrime(n) — Miller-style primality test
// ============================================================
abstraction SlideRule {
    capabilities { Constants }

    method Multiply(a, b) {
        acc = 0
        sign = 0
        if (b < 0) {
            b = 0 - b
            sign = sign + 1
        }
        if (a < 0) {
            a = 0 - a
            sign = sign + 1
        }
        while (b > 0) {
            low = bfext(b, 0, 1)
            if (low == 1) {
                acc = acc + a
            }
            a = a << 1
            b = b >> 1
        }
        if (sign == 1) {
            acc = 0 - acc
        }
        return(acc)
    }

    method Divide(a, b) {
        if (b == 0) {
            return(0)
        }
        sign = 0
        if (a < 0) {
            a = 0 - a
            sign = sign + 1
        }
        if (b < 0) {
            b = 0 - b
            sign = sign + 1
        }
        quot = 0
        while (a >= b) {
            a = a - b
            quot = quot + 1
        }
        if (sign == 1) {
            quot = 0 - quot
        }
        return(quot)
    }

    method Sqrt(n) {
        if (n == 0) {
            return(0)
        }
        if (n == 1) {
            return(1)
        }
        res = 0
        bit = 16384
        while (bit > 0) {
            test = res + bit
            if (n >= test) {
                n = n - test
                res = res >> 1
                res = res + bit
            } else {
                res = res >> 1
            }
            bit = bit >> 2
        }
        return(res)
    }

    method Mod(a, b) {
        if (b == 0) {
            return(0)
        }
        sign = 0
        if (a < 0) {
            a = 0 - a
            sign = 1
        }
        if (b < 0) {
            b = 0 - b
        }
        while (a >= b) {
            a = a - b
        }
        if (sign == 1) {
            a = 0 - a
        }
        return(a)
    }

    method Sin(angle) {
        neg = 0
        if (angle < 0) {
            angle = 0 - angle
            neg = 1
        }
        pi2 = 102944
        pi = 205887
        while (angle >= pi2) {
            angle = angle - pi2
        }
        x = 39797
        y = 0
        z = angle
        dx = y
        dy = x
        if (z >= 0) {
            x = x - dy
            y = y + dx
            z = z - 51472
        } else {
            x = x + dy
            y = y - dx
            z = z + 51472
        }
        dx = y >> 1
        dy = x >> 1
        if (z >= 0) {
