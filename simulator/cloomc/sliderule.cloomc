    method ToDegrees(radians) {
        sign = 0
        if (radians < 0) {
            radians = 0 - radians
            sign = 1
        }
        acc = 0
        r = 57
        while (r > 0) {
            low = bfext(r, 0, 1)
            if (low == 1) {
                acc = acc + radians
            }
            radians = radians << 1
            r = r >> 1
        }
        acc = acc >> 16
        if (sign == 1) {
            acc = 0 - acc
        }
        return(acc)
    }

    method ToRadians(degrees) {
        sign = 0
        if (degrees < 0) {
            degrees = 0 - degrees
            sign = 1
        }
        acc = 0
        r = 1144
        while (r > 0) {
            low = bfext(r, 0, 1)
            if (low == 1) {
                acc = acc + degrees
            }
            degrees = degrees << 1
            r = r >> 1
        }
        if (sign == 1) {
            acc = 0 - acc
        }
        return(acc)
    }

    method Bernoulli(n) {
        if (n == 0) {
            return(1, 1)
        }
        if (n == 1) {
            num = 0 - 1
            return(num, 2)
        }
        odd = bfext(n, 0, 1)
        if (odd == 1) {
            return(0, 1)
        }
        if (n == 2) {
            return(1, 6)
        }
        if (n == 4) {
            num = 0 - 1
            return(num, 30)
        }
        if (n == 6) {
            return(1, 42)
        }
        if (n == 8) {
            num = 0 - 1
            return(num, 30)
        }
        if (n == 10) {
            return(5, 66)
        }
        if (n == 12) {
            num = 0 - 691
            return(num, 2730)
        }
        if (n == 14) {
            return(7, 6)
        }
        if (n == 16) {
            num = 0 - 3617
            return(num, 510)
        }
        if (n == 18) {
            return(43867, 798)
        }
        if (n == 20) {
            num = 0 - 174611
            return(num, 330)
        }
        return(0, 1)
    }

    method Abs(n) {
        if (n < 0) {
            n = 0 - n
        }
        return(n)
    }

    method Pow(base, exp) {
        if (exp == 0) {
            return(1)
        }
        result = 1
        neg = 0
        if (exp < 0) {
            return(0)
        }
        if (base < 0) {
            odd = bfext(exp, 0, 1)
            if (odd == 1) {
                neg = 1
            }
            base = 0 - base
        }
        while (exp > 0) {
            acc = 0
            b = base
            r = result
            while (r > 0) {
                low = bfext(r, 0, 1)
                if (low == 1) {
                    acc = acc + b
                }
                b = b << 1
                r = r >> 1
            }
            result = acc
            exp = exp - 1
        }
        if (neg == 1) {
            result = 0 - result
        }
        return(result)
    }

    method Min(a, b) {
        if (a < b) {
            return(a)
        }
        return(b)
    }

    method Max(a, b) {
        if (a > b) {
            return(a)
        }
        return(b)
    }

    method GCD(a, b) {
        if (a < 0) {
            a = 0 - a
        }
        if (b < 0) {
            b = 0 - b
        }
        while (b > 0) {
            rem = a
            while (rem >= b) {
                rem = rem - b
            }
            a = b
            b = rem
        }
        return(a)
    }

    method Factorial(n) {
        if (n < 0) {
            return(0)
        }
        if (n == 0) {
            return(1)
        }
        result = 1
        while (n > 1) {
            acc = 0
            b = result
            r = n
            while (r > 0) {
                low = bfext(r, 0, 1)
                if (low == 1) {
                    acc = acc + b
                }
                b = b << 1
                r = r >> 1
            }
            result = acc
            n = n - 1
        }
        return(result)
    }

    method Log2(n) {
        if (n < 1) {
            return(0)
        }
        result = 0
        while (n > 1) {
            n = n >> 1
            result = result + 1
        }
        return(result)
    }

    method Atan2(y, x) {
        neg = 0
        if (y < 0) {
            y = 0 - y
