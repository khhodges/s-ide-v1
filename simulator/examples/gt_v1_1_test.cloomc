; GT Encoding v1.1 Hardware Self-Test
; =====================================
; A CLOOMC abstraction that exercises the live mLoad capability pipeline to
; verify that the dom+perm GT word layout is working correctly in hardware/sim.
;
; What is being tested:
;
;   The v1.1 GT word compresses six permission bits (R,W,X,L,S,E) into four
;   bits using Turing/Church mutual exclusion:
;
;     [31]    b_flag
;     [30:28] perm[2:0]  — {X,W,R} when dom=0 (Turing) or {E,S,L} when dom=1 (Church)
;     [27]    dom        — 0=Turing {XWR}, 1=Church {ESL}
;     [25]    f_flag     — Far indicator (per-token)
;     [24:23] gt_type
;     [22:16] gt_seq
;     [15:0]  slot_id
;
;   Domain purity is structurally enforced: a Church GT (dom=1) carries only
;   E/S/L bits, never X/W/R.  A Turing GT (dom=0) carries only X/W/R, never E.
;
;   TPERM EXACT (preset 14, new in v1.1) performs a 32-bit word-for-word
;   comparison between two CRs — useful for credential-pinning and boot-path
;   attestation.
;
; C-list slots used (populated by boot image):
;
;   Slot 7  (Boot.Nucs)  — X-GT: Turing domain, dom=0, perm[2]=X=1
;   Slot 3  (Boot.Abstr) — E-GT: Church domain, dom=1, perm[2]=E=1
;
; Result protocol:
;   DR14 = 0        → all six tests passed
;   DR14 = 1..6     → test N was the first to fail
;
; To run: paste into the simulator Code tab and click Run.
; All six assertions should complete without fault; DR14 stays 0.

; ── Load test GTs from the c-list ────────────────────────────────────────────
; CR6 is the active c-list capability (installed by boot sequence).
; LOAD CR1, CR6, 7  — pull the Turing X-GT (nucleus) into CR1
; LOAD CR2, CR6, 3  — pull the Church E-GT (Boot.Abstr) into CR2
; LOAD CR3, CR6, 7  — second handle to the X-GT for EXACT comparison

    LOAD CR1, CR6, 7        ; CR1 ← X-GT  (dom=0, perm=0b100, Turing execute)
    LOAD CR2, CR6, 3        ; CR2 ← E-GT  (dom=1, perm=0b100, Church invoke)
    LOAD CR3, CR6, 7        ; CR3 ← X-GT  (same token as CR1, for EXACT test)

; ── Test 1: X-GT satisfies TPERM X ──────────────────────────────────────────
; TPERM checks perm[2:0] after decoding dom.  A Turing GT with perm[2]=1
; carries X permission → Z=1 expected.

    TPERM CR1, X
    BRANCHEQ t2             ; Z=1 = correct → proceed to test 2
    DWRITE DR14, #1         ; Z=0 = FAIL — Turing X-GT did not satisfy TPERM X
    RETURN CR8

; ── Test 2: X-GT fails TPERM E ───────────────────────────────────────────────
; A Turing GT (dom=0) can never carry Church E permission (dom=1 required).
; TPERM E on a Turing GT must give Z=0.
t2:
    TPERM CR1, E
    BRANCHNE t3             ; Z=0 = correct → Turing GT correctly rejected Church check
    DWRITE DR14, #2         ; Z=1 = FAIL — Turing GT incorrectly passed Church E check
    RETURN CR8

; ── Test 3: E-GT satisfies TPERM E ───────────────────────────────────────────
; Church GT has dom=1, perm[2]=E=1 → TPERM E must give Z=1.
t3:
    TPERM CR2, E
    BRANCHEQ t4
    DWRITE DR14, #3         ; FAIL — Church E-GT did not satisfy TPERM E
    RETURN CR8

; ── Test 4: E-GT fails TPERM X ───────────────────────────────────────────────
; A Church GT (dom=1) carries no Turing bits.  TPERM X on it must give Z=0.
t4:
    TPERM CR2, X
    BRANCHNE t5             ; Z=0 = correct → Church GT correctly rejected Turing check
    DWRITE DR14, #4         ; Z=1 = FAIL — Church GT incorrectly passed Turing X check
    RETURN CR8

; ── Test 5: TPERM EXACT — identical GTs match (Z=1) ─────────────────────────
; CR1 and CR3 both hold the same X-GT word (loaded from the same c-list slot).
; TPERM EXACT does a 32-bit comparison of the raw GT words: CR1.word0 === CR3.word0.
t5:
    TPERM CR1, EXACT, CR3
    BRANCHEQ t6             ; Z=1 = correct → identical credentials match
    DWRITE DR14, #5         ; Z=0 = FAIL — identical GTs did not match under EXACT
    RETURN CR8

; ── Test 6: TPERM EXACT — different GTs do not match (Z=0) ──────────────────
; CR1 (X-GT, dom=0) and CR2 (E-GT, dom=1) have different GT words.
; TPERM EXACT must give Z=0 — the credentials are different tokens.
t6:
    TPERM CR1, EXACT, CR2
    BRANCHNE done           ; Z=0 = correct → different credentials correctly rejected
    DWRITE DR14, #6         ; Z=1 = FAIL — different GTs falsely matched under EXACT
    RETURN CR8

; ── All six tests passed ──────────────────────────────────────────────────────
done:
    DWRITE DR14, #0         ; 0 = all passed — dom+perm encoding and EXACT are correct
    RETURN CR8
